# Database Configuration
DATABASE_URL=postgres://postgres:mysecret@localhost:54322/maileroo

# Test Database URL for running integration tests against local Docker PostgreSQL.
# If commented out, integration tests fall back to using ultra-fast SQLite in-memory databases.
# WARNING: Running tests will drop/truncate tables, so we use a separate database name 'maileroo_test'.
# TEST_DATABASE_URL=postgres://postgres:mysecret@localhost:54322/maileroo_test

# Server addresses
SMTP_ADDR=0.0.0.0:2525
WEB_ADDR=0.0.0.0:3000

# Storage configuration
# Path where .eml files will be stored.
# Absolute path or relative to the project root.
STORAGE_DIR=./storage/emails

# Certificate paths (for production/dev)
CERTS_PATH=./certs
JWT_KEY='change-me'
SRS_SECRET='change-me'

# Set to true if accessed over HTTPS (via Caddy or directly), false if local pure HTTP dev
SECURE_COOKIES=false

COOKIE_DOMAIN=app.example.com
PROD_DOMAIN=example.com
EMAIL_DOMAINS=example.com

# --- Admin Bootstrapping ---
# These credentials are used to securely seed/update the initial administrator account on startup.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-to-a-secure-password


# --- Native Auto-TLS Configuration (Zero-Proxy Setup) ---
# Set to true to let Maileroo handle Let's Encrypt certificates natively (no Caddy required).
# This binds port 80 (HTTP redirect / ACME challenges) and 443 (HTTPS) dynamically.
# AUTO_TLS=false

# Your Let's Encrypt registration and notification email (Required if AUTO_TLS=true)
# ACME_EMAIL=admin@yourdomain.com

# Directory path where certificates and ACME accounts will be cached on disk.
# Defaults to './storage/certs/acme'
# ACME_CACHE_DIR=./storage/certs/acme

# Optional: ACME server directory (Defaults to Let's Encrypt Production)
# Use Let's Encrypt Staging for initial dry-run tests to prevent hitting rate limits:
# ACME_DIRECTORY=https://acme-staging-v02.api.letsencrypt.org/directory

# Optional: Override ports bound under AUTO_TLS (Useful for docker/port-forwarding, default is 80 and 443)
# AUTO_TLS_HTTP_PORT=80
# AUTO_TLS_HTTPS_PORT=443

# --- Outbound SMTP Relay Configuration ---
# To bypass cloud provider Port 25 blocks, Maileroo can route outbound emails 
# through an upstream SMTP relay (e.g. Mailtrap, SendGrid, Postmark, Amazon SES).
# 
# Setting SMTP_RELAY_TOKEN enables relay mode. If empty, Maileroo falls back to direct MX resolution on Port 25.
# SMTP_RELAY_TOKEN=your_upstream_smtp_password_or_api_key_here

# Optional: Overrides if NOT using Mailtrap's live production SMTP API.
# Maileroo automatically defaults to Mailtrap's production values if left empty:
# SMTP_RELAY_HOST=live.smtp.mailtrap.io
# SMTP_RELAY_PORT=587
# SMTP_RELAY_USER=api

# --- Outbound SMTP Relay Live Verification (Optional) ---
# Used exclusively by the offline `smtp_relay_test` binary (cargo run --bin smtp_relay_test).
# These prefix with `TEST_` to prevent any overlap or accidents with the active production server.
#
# If using Mailtrap's free developer sandbox, find your credentials here:
# https://mailtrap.io/sandboxes/projects
#
# TEST_SMTP_RELAY_TOKEN=your_mailtrap_sandbox_password_here
# TEST_SMTP_RELAY_HOST=sandbox.smtp.mailtrap.io
# TEST_SMTP_RELAY_PORT=2525
# TEST_SMTP_RELAY_USER=your_mailtrap_sandbox_username_here
# TEST_RECIPIENT_EMAIL=any_test_inbox@domain.com
# TEST_SENDER_EMAIL=hello@example.com
